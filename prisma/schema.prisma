generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(100)
  email         String   @unique @db.VarChar(100)
  phone         String?  @unique @db.VarChar(20)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  activityLogs      ActivityLog[]

  @@map("users")
}

model Building {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  ownerName   String?  @map("owner_name") @db.VarChar(100)
  address     String?  @db.VarChar(255)
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  floorsCount Int      @default(0) @map("floors_count")
  unitsCount  Int      @default(0) @map("units_count")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  floors    Floor[]
  units     Unit[]
  contracts LeaseContract[]
  dues      Due[]
  receipts  Receipt[]

  @@map("buildings")
}

model Floor {
  id         String   @id @default(uuid()) @db.Uuid
  buildingId String   @map("building_id") @db.Uuid
  name       String   @db.VarChar(50)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  building Building @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  units    Unit[]

  @@unique([buildingId, name])
  @@map("floors")
}

model Unit {
  id                     String   @id @default(uuid()) @db.Uuid
  buildingId             String   @map("building_id") @db.Uuid
  floorId                String?  @map("floor_id") @db.Uuid
  unitNumber             String   @map("unit_number") @db.VarChar(50)
  unitType               String   @map("unit_type") @db.VarChar(30)
  area                   Decimal? @db.Decimal(10, 2)
  roomsCount             Int?     @map("rooms_count")
  bathroomsCount         Int?     @map("bathrooms_count")
  defaultRent            Decimal? @map("default_rent") @db.Decimal(12, 2)
  electricityMeterNumber      String?  @map("electricity_meter_number") @db.VarChar(50)
  waterMeterNumber            String?  @map("water_meter_number") @db.VarChar(50)
  currentElectricityMeterReading String? @map("current_electricity_meter_reading") @db.VarChar(50)
  currentWaterMeterReading       String? @map("current_water_meter_reading") @db.VarChar(50)
  status                      String   @default("empty") @db.VarChar(20)
  notes                  String?  @db.Text
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  building  Building        @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  floor     Floor?          @relation(fields: [floorId], references: [id], onDelete: SetNull)
  contracts LeaseContract[]
  dues      Due[]
  receipts  Receipt[]
  evictions Eviction[]

  @@unique([buildingId, unitNumber])
  @@map("units")
}

model Tenant {
  id             String   @id @default(uuid()) @db.Uuid
  fullName       String   @map("full_name") @db.VarChar(100)
  nationalId     String?  @map("national_id") @db.VarChar(50)
  phone          String?  @db.VarChar(20)
  email          String?  @db.VarChar(100)
  address        String?  @db.VarChar(255)
  workplace      String?  @db.VarChar(100)
  guarantorName  String?  @map("guarantor_name") @db.VarChar(100)
  guarantorPhone String?  @map("guarantor_phone") @db.VarChar(20)
  identityImage  String?  @map("identity_image") @db.VarChar(255)
  notes          String?  @db.Text
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  contracts LeaseContract[]
  dues      Due[]
  receipts  Receipt[]
  evictions Eviction[]

  @@map("tenants")
}

model LeaseContract {
  id                        String    @id @default(uuid()) @db.Uuid
  contractNumber            String    @map("contract_number") @db.VarChar(50)
  tenantId                  String    @map("tenant_id") @db.Uuid
  buildingId                String    @map("building_id") @db.Uuid
  unitId                    String    @map("unit_id") @db.Uuid
  previousContractId        String?   @unique @map("previous_contract_id") @db.Uuid
  startDate                 DateTime  @map("start_date") @db.Date
  endDate                   DateTime  @map("end_date") @db.Date
  rentAmount                Decimal   @map("rent_amount") @db.Decimal(12, 2)
  paymentFrequency          String    @map("payment_frequency") @db.VarChar(20)
  paymentMethod             String?   @map("payment_method") @db.VarChar(50)
  electricityResponsibility String?   @map("electricity_responsibility") @db.VarChar(50)
  waterResponsibility       String?   @map("water_responsibility") @db.VarChar(50)
  maintenanceResponsibility String?   @map("maintenance_responsibility") @db.VarChar(50)
  servicesResponsibility  String?   @map("services_responsibility") @db.VarChar(50)
  commitmentTiming        String?   @map("commitment_timing") @db.VarChar(20) @default("start")
  contractDate              DateTime? @map("contract_date") @db.Date
  firstDueDate              DateTime? @map("first_due_date") @db.Date
  terms                     String?   @db.Text
  witnesses                 String?   @db.Text
  status                    String    @default("draft") @db.VarChar(20)
  notes                     String?   @db.Text
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  building         Building        @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  unit             Unit            @relation(fields: [unitId], references: [id], onDelete: Restrict)
  previousContract LeaseContract?  @relation("ContractRenewal", fields: [previousContractId], references: [id], onDelete: SetNull)
  renewedContract  LeaseContract?  @relation("ContractRenewal")
  dues             Due[]
  receipts         Receipt[]
  evictions        Eviction[]
  attachments      ContractAttachment[]

  @@unique([contractNumber])
  @@map("lease_contracts")
}

model ContractAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  contractId String   @map("contract_id") @db.Uuid
  fileName   String   @map("file_name") @db.VarChar(255)
  fileType   String   @map("file_type") @db.VarChar(50)
  fileData   String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  contract LeaseContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_attachments")
}

model DueType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(50)
  isSystem  Boolean  @default(false) @map("is_system")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  dues Due[]

  @@map("due_types")
}

model Due {
  id                 String    @id @default(uuid()) @db.Uuid
  dueNumber          String    @map("due_number") @db.VarChar(50)
  tenantId           String    @map("tenant_id") @db.Uuid
  contractId         String?   @map("contract_id") @db.Uuid
  buildingId         String?   @map("building_id") @db.Uuid
  unitId             String?   @map("unit_id") @db.Uuid
  dueTypeId          String    @map("due_type_id") @db.Uuid
  transactionDate    DateTime  @map("transaction_date") @db.Date
  dueDate            DateTime  @map("due_date") @db.Date
  periodLabel        String?   @map("period_label") @db.VarChar(50)
  description        String?   @db.Text
  amount             Decimal   @db.Decimal(12, 2)
  sourceType         String    @map("source_type") @db.VarChar(30)
  referenceNumber    String?   @map("reference_number") @db.VarChar(50)
  status             String    @default("approved") @db.VarChar(20)
  cancellationReason String?   @map("cancellation_reason") @db.Text
  cancelledBy        String?   @map("cancelled_by") @db.Uuid
  cancelledAt        DateTime? @map("cancelled_at") @db.Timestamptz(6)
  notes              String?   @db.Text
  previousMeterReading String? @map("previous_meter_reading") @db.VarChar(50)
  currentMeterReading  String? @map("current_meter_reading") @db.VarChar(50)
  meterConsumption     String? @map("meter_consumption") @db.VarChar(50)
  unitPrice            Decimal? @map("unit_price") @db.Decimal(12, 2)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contract     LeaseContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  building     Building?   @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  unit         Unit?       @relation(fields: [unitId], references: [id], onDelete: SetNull)
  dueType      DueType     @relation(fields: [dueTypeId], references: [id], onDelete: Restrict)

  @@map("dues")
}

model Receipt {
  id              String   @id @default(uuid()) @db.Uuid
  receiptNumber   String   @map("receipt_number") @db.VarChar(50)
  tenantId        String   @map("tenant_id") @db.Uuid
  contractId      String?  @map("contract_id") @db.Uuid
  buildingId      String?  @map("building_id") @db.Uuid
  unitId          String?  @map("unit_id") @db.Uuid
  receiptDate     DateTime @map("receipt_date") @db.Date
  amount          Decimal  @db.Decimal(12, 2)
  paymentMethod   String   @map("payment_method") @db.VarChar(20)
  referenceNumber String?  @map("reference_number") @db.VarChar(50)
  chequeImage     String?  @map("cheque_image") @db.VarChar(255)
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  contract LeaseContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  building Building?      @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  unit     Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@map("receipts")
}

model Eviction {
  id                     String   @id @default(uuid()) @db.Uuid
  contractId             String   @map("contract_id") @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  unitId                 String   @map("unit_id") @db.Uuid
  evictionDate           DateTime @map("eviction_date") @db.Date
  electricityMeterReading String? @map("electricity_meter_reading") @db.VarChar(50)
  waterMeterReading      String?  @map("water_meter_reading") @db.VarChar(50)
  notes                  String?  @db.Text
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  contract LeaseContract @relation(fields: [contractId], references: [id], onDelete: Restrict)
  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  unit     Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@map("evictions")
}

model Setting {
  id          String   @id @default(uuid()) @db.Uuid
  settingKey  String   @unique @map("setting_key") @db.VarChar(100)
  settingValue Json?   @map("setting_value") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("settings")
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  actionType String   @map("action_type") @db.VarChar(50)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values") @db.JsonB
  newValues  Json?    @map("new_values") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_logs")
}
